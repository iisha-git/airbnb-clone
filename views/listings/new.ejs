<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderLust</title>
</head>
<body>
    <h3>create a New Listing</h3>
    <form method="POST" action="/listings">
        <input placeholder="enter title" type = "text" name="listing[title]">
        <br><br>
        <textarea name="listing[description]" placeholder="enter description"></textarea>
        <br><br>
        <input placeholder="enter image url/link" name="listing[image]">
        <br><br>
        <input placeholder="number" type="number" name="listing[price]">
        <br><br>
        <input placeholder="enter location" type="text" name="listing[location]">
        <br><br>
        <input placeholder="enter country" name="listing[country]">
        <br><br>
        <button>Add</button>
        
    </form>
</body>
</html>